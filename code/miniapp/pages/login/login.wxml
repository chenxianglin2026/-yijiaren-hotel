<view class="page-login">
  <!-- 顶部品牌标识 -->
  <view class="login-header">
    <view class="login-logo-wrap img-placeholder">
      <text class="login-logo-text">伊</text>
    </view>
    <text class="login-title">伊家人酒店</text>
    <text class="login-subtitle text-light">品质睡眠 · 舒心入住</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <!-- 手机号输入 -->
    <view class="input-group">
      <text class="input-label">手机号码</text>
      <view class="input-wrap">
        <text class="input-prefix">+86</text>
        <input
          class="input-field"
          type="number"
          maxlength="11"
          placeholder="请输入手机号码"
          placeholder-style="color:#D0C8B8;font-size:30rpx;"
          value="{{phoneNumber}}"
          bindinput="onPhoneInput"
          focus="{{autoFocus}}"
        />
        <text class="input-clear" wx:if="{{phoneNumber}}" bindtap="onClearPhone">✕</text>
      </view>
    </view>

    <!-- 验证码输入 -->
    <view class="input-group">
      <text class="input-label">验证码</text>
      <view class="input-wrap">
        <input
          class="input-field"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-style="color:#D0C8B8;font-size:30rpx;"
          value="{{verifyCode}}"
          bindinput="onCodeInput"
        />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="onSendCode">
          <text wx:if="{{countdown === 0}}">获取验证码</text>
          <text wx:else>{{countdown}}s后重发</text>
        </view>
      </view>
    </view>

    <!-- 用户协议 -->
    <view class="agreement-row">
      <view class="checkbox-wrap" bindtap="onToggleAgree">
        <text class="checkbox {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</text>
      </view>
      <text class="agreement-text text-sm text-light">
        已阅读并同意
        <text class="agreement-link" catchtap="onShowAgreement" data-type="service">《用户服务协议》</text>
        和
        <text class="agreement-link" catchtap="onShowAgreement" data-type="privacy">《隐私政策》</text>
      </text>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn {{canLogin ? '' : 'disabled'}}" bindtap="onLogin">
      <text>登录</text>
    </view>

    <!-- 其他登录方式 -->
    <view class="other-login">
      <view class="other-line">
        <view class="line-dot"></view>
        <text class="other-text text-sm text-light">其他登录方式</text>
        <view class="line-dot"></view>
      </view>
      <view class="other-methods">
        <button class="wechat-btn" open-type="getPhoneNumber" bindgetphonenumber="onWechatPhoneLogin">
          <text class="wechat-icon">💬</text>
          <text class="wechat-text">微信手机号一键登录</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="login-footer">
    <text class="footer-text text-sm text-light">登录即表示您同意以上协议</text>
    <text class="footer-text text-sm text-light mt-6">伊家人酒店保障您的信息安全</text>
  </view>
</view>
