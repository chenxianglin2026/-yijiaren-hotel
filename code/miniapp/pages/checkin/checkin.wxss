/* ========== 入住开锁 ========== */

.page-checkin {
  background: #FAF7F2;
  min-height: 100vh;
}

/* ---- 加载 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #B0A492;
}

/* ---- 空状态 ---- */
.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7E6A;
  margin-top: 20rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #B0A492;
}

/* ---- 信息网格 ---- */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  padding: 10rpx 0;
}

.info-label {
  font-size: 22rpx;
  color: #B0A492;
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #3D3226;
}

.room-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #C8A96E;
}

/* ---- 身份证上传 ---- */
.idcard-hint {
  display: block;
}

.idcard-grid {
  display: flex;
  gap: 20rpx;
}

.idcard-item {
  flex: 1;
}

.idcard-img-wrap {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F8F5EF;
  border: 2rpx dashed #E8E0D5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.idcard-img {
  width: 100%;
  height: 100%;
}

.idcard-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.idcard-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.idcard-label {
  font-size: 24rpx;
  color: #8B7E6A;
  font-weight: 500;
}

.idcard-sub {
  font-size: 20rpx;
  color: #B0A492;
  margin-top: 4rpx;
}

.idcard-status {
  display: block;
  text-align: center;
  color: #6BAA75;
  margin-top: 8rpx;
}

/* ---- 人脸识别 ---- */
.face-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.face-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F5F0E8, #EDE5D8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.face-icon-wrap.verified {
  background: linear-gradient(135deg, #D4F0D8, #B8E6C0);
}

.face-icon {
  font-size: 64rpx;
}

.face-title {
  font-size: 28rpx;
  color: #3D3226;
  font-weight: 500;
}

.face-desc {
  text-align: center;
  line-height: 1.5;
  max-width: 500rpx;
}

.face-btn {
  padding: 18rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* ---- 开锁方式Tab ---- */
.unlock-tabs {
  display: flex;
  margin: 20rpx 30rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(61,50,38,0.06);
}

.unlock-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
  transition: all 0.2s ease;
}

.unlock-tab.active {
  background: rgba(200, 169, 110, 0.08);
}

.unlock-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #C8A96E;
  border-radius: 2rpx;
}

.unlock-tab-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.unlock-tab-label {
  font-size: 24rpx;
  color: #8B7E6A;
}

.unlock-tab.active .unlock-tab-label {
  color: #C8A96E;
  font-weight: 600;
}

/* ---- 开锁卡片 ---- */
.unlock-card {
  margin-bottom: 16rpx;
}

/* ---- 蓝牙开锁 ---- */
.ble-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lock-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lock-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5F0E8, #EDE5D8);
  box-shadow: 0 8rpx 30rpx rgba(61,50,38,0.1);
  transition: all 0.3s ease;
}

.lock-circle.unlocked {
  background: linear-gradient(135deg, #D4F0D8, #B8E6C0);
  box-shadow: 0 8rpx 30rpx rgba(107,170,117,0.2);
}

.lock-circle.unlocking {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  animation: pulse 0.8s ease infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.lock-icon {
  font-size: 72rpx;
}

.lock-status-text {
  font-size: 28rpx;
  color: #8B7E6A;
}

.ble-steps {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F8F5EF;
  border-radius: 12rpx;
  padding: 24rpx;
}

.ble-step {
  display: flex;
  align-items: center;
}

.ble-step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #C8A96E;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.ble-step-text {
  font-size: 26rpx;
  color: #3D3226;
}

.lock-actions {
  display: flex;
  justify-content: center;
}

.lock-btn {
  min-width: 300rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.ble-status-bar {
  text-align: center;
}

/* ---- 密码开锁 ---- */
.code-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-hint {
  display: block;
  text-align: center;
}

.code-display {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.code-digit {
  width: 72rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #3D3226;
  background: #F8F5EF;
  border-radius: 10rpx;
  letter-spacing: 4rpx;
}

.code-actions {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

/* ---- 二维码开锁 ---- */
.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-display {
  display: flex;
  justify-content: center;
}

.qr-code-wrap {
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(61,50,38,0.08);
}

.qr-mock {
  width: 320rpx;
  height: 320rpx;
  position: relative;
  background: #FFFFFF;
}

.qr-pattern {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

.qr-row {
  display: flex;
  flex: 1;
}

.qr-cell {
  flex: 1;
  background: #FFFFFF;
}

.qr-cell.dark {
  background: #3D3226;
}

.qr-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 8rpx #FFFFFF;
}

.qr-center-icon {
  font-size: 40rpx;
}

.qr-actions {
  display: flex;
  justify-content: center;
}

.qr-timer {
  text-align: center;
}

/* ---- WiFi ---- */
.wifi-info {
  background: #F8F5EF;
  border-radius: 12rpx;
  padding: 24rpx;
}

.wifi-row {
  display: block;
  font-size: 28rpx;
  color: #3D3226;
}

/* ---- 酒店服务 ---- */
.service-grid {
  display: flex;
  flex-wrap: wrap;
}

.service-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.service-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.service-label {
  font-size: 24rpx;
  color: #3D3226;
  font-weight: 500;
}

.service-desc {
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* ---- 附近推荐 ---- */
.nearby-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nearby-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F0E8;
}

.nearby-item:last-child {
  border-bottom: none;
}

.nearby-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.nearby-name {
  font-size: 26rpx;
  color: #3D3226;
}

.nearby-distance {
  font-size: 24rpx;
}
