/* ========== 入住开锁 ========== */

.page-checkin {
  background: #FAF7F2;
  min-height: 100vh;
}

/* ---- 加载 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #B0A492;
}

/* ---- 空状态 ---- */
.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7E6A;
  margin-top: 20rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #B0A492;
}

/* ---- 信息网格 ---- */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  padding: 10rpx 0;
}

.info-label {
  font-size: 22rpx;
  color: #B0A492;
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #3D3226;
}

.room-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #C8A96E;
}

/* ---- 智能门锁 ---- */
.lock-section {
  text-align: center;
}

.lock-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lock-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5F0E8, #EDE5D8);
  box-shadow: 0 8rpx 30rpx rgba(61,50,38,0.1);
  transition: all 0.3s ease;
}

.lock-circle.unlocked {
  background: linear-gradient(135deg, #D4F0D8, #B8E6C0);
  box-shadow: 0 8rpx 30rpx rgba(107,170,117,0.2);
}

.lock-circle.unlocking {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  animation: pulse 0.8s ease infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.lock-icon {
  font-size: 72rpx;
}

.lock-status-text {
  font-size: 28rpx;
  color: #8B7E6A;
}

.lock-actions {
  display: flex;
  justify-content: center;
}

.lock-btn {
  min-width: 300rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* ---- 开门密码 ---- */
.code-display {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.code-digit {
  width: 72rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #3D3226;
  background: #F8F5EF;
  border-radius: 10rpx;
  letter-spacing: 4rpx;
}

.code-actions {
  display: flex;
  justify-content: center;
}

.code-hint {
  display: block;
  text-align: center;
}

/* ---- WiFi ---- */
.wifi-info {
  background: #F8F5EF;
  border-radius: 12rpx;
  padding: 24rpx;
}

.wifi-row {
  display: block;
  font-size: 28rpx;
  color: #3D3226;
}

/* ---- 酒店服务 ---- */
.service-grid {
  display: flex;
  flex-wrap: wrap;
}

.service-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.service-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.service-label {
  font-size: 24rpx;
  color: #3D3226;
  font-weight: 500;
}

.service-desc {
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* ---- 附近推荐 ---- */
.nearby-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nearby-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F0E8;
}

.nearby-item:last-child {
  border-bottom: none;
}

.nearby-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.nearby-name {
  font-size: 26rpx;
  color: #3D3226;
}

.nearby-distance {
  font-size: 24rpx;
}
