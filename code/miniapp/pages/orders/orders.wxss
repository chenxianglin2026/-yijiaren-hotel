/* ========== 我的订单 ========== */

.page-orders {
  background: #FAF7F2;
  min-height: 100vh;
}

/* ---- Tab栏 ---- */
.tabs-bar {
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0EBE0;
  position: sticky;
  top: 0;
  z-index: 50;
}

.tabs-scroll {
  display: flex;
  white-space: nowrap;
  padding: 0 20rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #8B7E6A;
  position: relative;
}

.tab-item.active {
  color: #C8A96E;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #C8A96E;
  border-radius: 2rpx;
}

.tab-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background: #C56C6C;
  border-radius: 16rpx;
  margin-left: 6rpx;
  line-height: 1;
}

.tab-item.active .tab-badge {
  background: #C8A96E;
}

/* ---- 订单统计 ---- */
.order-summary {
  display: flex;
  margin: 20rpx 30rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(61,50,38,0.06);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.summary-item::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background: #F0EBE0;
}

.summary-item:last-child::after {
  display: none;
}

.summary-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D3226;
  line-height: 1;
}

.summary-label {
  font-size: 22rpx;
  color: #B0A492;
  margin-top: 8rpx;
}

/* ---- 加载 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #B0A492;
}

/* ---- 空状态 ---- */
.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7E6A;
  margin-top: 20rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #B0A492;
}

/* ---- 订单卡片 ---- */
.order-list {
  padding-bottom: 20rpx;
}

.order-card {
  margin-bottom: 16rpx;
}

.order-header {
  padding: 4rpx 0;
}

.order-store {
  font-size: 28rpx;
}

.order-date {
  font-size: 22rpx;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.order-status.pending {
  color: #E8A84C;
}

.order-status.paid {
  color: #6BAA75;
}

.order-status.staying {
  color: #C8A96E;
}

.order-status.completed {
  color: #8B7E6A;
}

.order-status.cancelled {
  color: #C56C6C;
}

/* ---- 订单内容 ---- */
.order-body {
}

.order-room-img {
  width: 140rpx;
  height: 120rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-room-icon {
  font-size: 50rpx;
  opacity: 0.4;
}

.order-room-name {
  font-size: 28rpx;
}

.order-info {
  display: flex;
}

/* ---- 订单底部 ---- */
.order-footer {
  padding: 4rpx 0;
}

.order-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-sm {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
}

/* ---- 加载更多 ---- */
.loading-more {
  display: flex;
  justify-content: center;
  padding: 30rpx;
}
