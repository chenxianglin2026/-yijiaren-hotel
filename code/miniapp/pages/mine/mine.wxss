/* ========== 我的 ========== */

.page-mine {
  background: #FAF7F2;
  min-height: 100vh;
}

/* ---- 用户头部 ---- */
.user-header {
  background: linear-gradient(135deg, #c8a052, #D4B896);
  padding: 40rpx 30rpx 50rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-placeholder {
  font-size: 48rpx;
  background: rgba(255,255,255,0.2);
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.login-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.6);
  margin-left: 12rpx;
}

/* ---- 会员卡片 ---- */
.member-card {
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
  background: linear-gradient(135deg, #FFF8EC, #FFF3E0);
  border: 1rpx solid rgba(200, 169, 110, 0.2);
}

.member-icon {
  font-size: 44rpx;
}

.member-level {
  font-size: 28rpx;
  font-weight: 600;
  color: #A8894E;
}

.member-points {
  font-size: 24rpx;
}

.member-coupons {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.coupon-count {
  font-size: 40rpx;
  font-weight: 700;
  color: #c8a052;
  line-height: 1;
}

.coupon-label {
  margin-top: 4rpx;
}

/* ---- 订单统计 ---- */
.order-stats {
  margin-top: 20rpx;
}

.stats-header {
  padding-bottom: 0;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3226;
}

.stats-grid {
  display: flex;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D3226;
}

.stat-label {
  font-size: 24rpx;
  color: #8B7E6A;
  margin-top: 4rpx;
}

/* ---- 快捷操作 ---- */
.quick-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-label {
  font-size: 24rpx;
  color: #8B7E6A;
}

/* ---- 菜单 ---- */
.menu-section {
  margin-top: 20rpx;
}

.menu-group {
  margin-top: 0;
  margin-bottom: 0;
  border-radius: 20rpx;
}

.menu-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F0E8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  width: 60rpx;
  text-align: center;
}

.menu-label {
  font-size: 28rpx;
  color: #3D3226;
  font-weight: 500;
}

.menu-desc {
  font-size: 24rpx;
}

.menu-badge {
  font-size: 24rpx;
  color: #FFFFFF;
  background: #C56C6C;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #D0C8B8;
}

/* ---- 退出登录 ---- */
.logout-section {
  margin-top: 40rpx;
}

.logout-btn {
  text-align: center;
  padding: 24rpx;
}

.logout-text {
  font-size: 28rpx;
  color: #C56C6C;
}

/* ---- 底部 ---- */
.footer {
  text-align: center;
  padding: 40rpx 0;
  color: #B0A492;
}
