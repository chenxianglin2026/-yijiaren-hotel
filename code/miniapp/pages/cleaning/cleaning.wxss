/* ========== 保洁端 ========== */

.page-cleaning {
  min-height: 100vh;
  background: #FAF7F2;
  padding-bottom: 120rpx;
}

/* ---- 统计条 ---- */
.stats-bar {
  display: flex;
  background: linear-gradient(135deg, #C8A96E, #D4B896);
  padding: 30rpx 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* ---- Tab 切换 ---- */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E8E0D5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #8B7E6A;
  position: relative;
  transition: color 0.2s;
}

.tab-item.active {
  color: #C8A96E;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #C8A96E;
  border-radius: 2rpx;
}

/* ---- 工单列表 ---- */
.task-list {
  padding: 20rpx 24rpx;
}

/* ---- 工单卡片 ---- */
.task-card {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 50, 38, 0.05);
}

.task-status-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.task-body {
  flex: 1;
  min-width: 0;
}

.task-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.task-room {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3226;
}

.task-type-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: rgba(200, 169, 110, 0.12);
  color: #C8A96E;
  border-radius: 6rpx;
}

.task-status-text {
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.task-notes {
  display: block;
  font-size: 24rpx;
  color: #8B7E6A;
  line-height: 1.5;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-time {
  font-size: 22rpx;
  color: #B0A492;
}

/* ---- 右侧操作按钮 ---- */
.task-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
}

.btn-accept,
.btn-start,
.btn-checkin,
.btn-detail {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.btn-accept {
  background: linear-gradient(135deg, #C8A96E, #D4B896);
  color: #FFFFFF;
}

.btn-start {
  background: #5B8DEF;
  color: #FFFFFF;
}

.btn-checkin {
  background: #6BAA75;
  color: #FFFFFF;
}

.btn-detail {
  background: #F5F5F5;
  color: #8B7E6A;
}

/* ---- 完工打卡弹窗 ---- */
.checkin-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.checkin-popup {
  width: 100%;
  max-height: 90vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 30rpx 30rpx;
  overflow-y: auto;
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #E8E0D5;
}

.checkin-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3D3226;
}

.checkin-close {
  font-size: 36rpx;
  color: #B0A492;
  padding: 10rpx;
}

.checkin-room-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
}

.checkin-room {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3226;
}

.checkin-type {
  font-size: 24rpx;
  color: #C8A96E;
  padding: 4rpx 16rpx;
  background: rgba(200, 169, 110, 0.12);
  border-radius: 6rpx;
}

/* ---- 拍照区域 ---- */
.checkin-photo-area {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #D4B896;
  background: #FAF7F2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
}

.checkin-photo {
  width: 100%;
  height: 100%;
}

.photo-retake {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.4);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.photo-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.photo-hint {
  font-size: 28rpx;
  color: #8B7E6A;
  font-weight: 500;
}

.photo-sub {
  font-size: 22rpx;
  color: #B0A492;
  margin-top: 8rpx;
}

/* ---- 备注输入 ---- */
.checkin-note-wrap {
  position: relative;
  margin: 16rpx 0 24rpx;
}

.checkin-note {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: #F8F5EF;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #3D3226;
  box-sizing: border-box;
}

.note-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: #B0A492;
}

/* ---- 提交按紐 ---- */
.checkin-footer {
  padding-bottom: env(safe-area-inset-bottom);
}

.checkin-submit {
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
  border-radius: 16rpx;
}

.checkin-submit.disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* ---- 加载 & 空状态 ---- */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #B0A492;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7E6A;
}

.empty-hint {
  font-size: 24rpx;
  color: #B0A492;
}
