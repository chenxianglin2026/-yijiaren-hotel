/* ========== 首页 ========== */

.page-index {
  padding-bottom: 100rpx;
  min-height: 100vh;
}

/* ---- 顶部栏 ---- */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  background: linear-gradient(135deg, #c8a052, #D4B896);
}

.location-wrap {
  display: flex;
  align-items: center;
  min-width: 180rpx;
}

.location-icon {
  font-size: 28rpx;
}

.location-city {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin: 0 6rpx;
}

.location-arrow {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.header-title {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.header-placeholder {
  width: 180rpx;
}

/* ---- 搜索栏 ---- */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0EBE0;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F8F5EF;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #3D3226;
}

.search-clear {
  font-size: 28rpx;
  color: #B0A492;
  padding: 0 10rpx;
}

.filter-btn {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #8B7E6A;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #F8F5EF;
}

.filter-btn.active {
  background: rgba(200, 169, 110, 0.12);
  color: #c8a052;
}

/* ---- 筛选面板 ---- */
.filter-panel {
  background: #FFFFFF;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #E8E0D5;
}

.filter-row {
  display: flex;
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #3D3226;
  font-weight: 500;
  width: 80rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.filter-options {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  font-size: 24rpx;
  color: #8B7E6A;
  padding: 8rpx 24rpx;
  background: #F8F5EF;
  border-radius: 30rpx;
  transition: all 0.2s;
}

.filter-tag.active {
  background: rgba(200, 169, 110, 0.15);
  color: #c8a052;
  font-weight: 500;
}

.filter-actions {
  text-align: right;
}

.filter-reset {
  font-size: 24rpx;
  color: #B0A492;
  padding: 8rpx 16rpx;
}

/* ---- Banner ---- */
.banner-swiper {
  height: 340rpx;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-slide {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.banner-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

/* ---- 特色 ---- */
.features-section {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx 30rpx 20rpx;
}

.feature-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.feature-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.feature-label {
  font-size: 24rpx;
  color: #3D3226;
  font-weight: 500;
}

.feature-desc {
  font-size: 24rpx;
  color: #B0A492;
  margin-top: 4rpx;
}

/* ---- 门店卡片 ---- */
.store-card {
  margin-top: 0;
}

.store-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3226;
}

.store-addr {
  font-size: 24rpx;
  color: #8B7E6A;
}

/* ---- 区块标题 ---- */
.section-header {
  display: flex;
  align-items: baseline;
  padding: 30rpx 30rpx 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3D3226;
}

.section-sub {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #B0A492;
}

/* ---- 加载 ---- */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #B0A492;
}

/* ---- 空状态 ---- */
.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7E6A;
  margin-top: 20rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #B0A492;
}

/* ---- 房型卡片 ---- */
.room-list {
  padding-bottom: 20rpx;
}

.room-card {
  margin-bottom: 10rpx;
}

.room-card-inner {
  overflow: hidden;
}

.room-image-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.room-tags-top {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.room-tag-item {
  font-size: 24rpx;
  color: #FFFFFF;
  background: rgba(200, 169, 110, 0.85);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.room-name {
  font-size: 32rpx;
}

.room-type-tag {
  font-size: 24rpx;
}

.room-desc {
  line-height: 1.5;
}

.room-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #8B7E6A;
}

.room-price {
  display: flex;
  align-items: baseline;
}

.price-original {
  font-size: 24rpx;
  color: #B0A492;
}

.room-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.room-stock {
  font-size: 24rpx;
  color: #C56C6C;
  font-weight: 500;
}

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  border-radius: 30rpx;
}
