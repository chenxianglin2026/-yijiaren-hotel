# ============================================================
# 伊家人酒店系统 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# ── 应用基础 ──────────────────────────────────────────
APP_NAME=伊家人酒店系统
APP_VERSION=1.0.0
DEBUG=true

# ── 数据库模式 ────────────────────────────────────────
# true = 开发模式(本地 SQLite 文件)
# false = 生产模式(PostgreSQL)
DEV_MODE=false

# ── PostgreSQL 连接（DEV_MODE=false 时生效）───────────
POSTGRES_DB=yijiaren
POSTGRES_USER=yijiaren
POSTGRES_PASSWORD=yijiaren123
# 容器内连接（docker-compose）
DATABASE_URL=postgresql+asyncpg://yijiaren:yijiaren123@postgres:5432/yijiaren
# VPS 宿主机直连数据库（不使用 docker-compose 时）
# DATABASE_URL=postgresql+asyncpg://yijiaren:yijiaren123@localhost:5432/yijiaren

# ── JWT 认证 ─────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8000", "http://localhost:3000", "http://43.163.5.90"]

# ── 微信小程序 ────────────────────────────────────────
WX_APPID=wx15932207fb03a5a4
WX_SECRET=97acd5a0ca02fd5b03814fc51a34e9fa

# ── 服务器域名（用于支付回调等） ──────────────────────
SERVER_DOMAIN=http://43.163.5.90:8001

# ── 微信支付（V3 API）────────────────────────────────
WX_MCHID=
WX_PAY_KEY=
WX_PAY_SERIAL=
WX_PAY_PRIVATE_KEY=
# 优先使用此项；为空则自动由 SERVER_DOMAIN + /api/payment/notify 拼接
WX_PAY_NOTIFY_URL=

# ── 智能门锁 TTLock ──────────────────────────────────
TTLOCK_CLIENT_ID=4433c6c075e8490ea00c6a60a9e31cd8
TTLOCK_CLIENT_SECRET=

# ── OTA 渠道（携程/美团/飞猪）────────────────────────
# OTA_CTRIP_API_KEY=
# OTA_CTRIP_API_SECRET=
# OTA_MEITUAN_API_KEY=
# OTA_MEITUAN_API_SECRET=
# OTA_FLIGGY_API_KEY=
# OTA_FLIGGY_API_SECRET=
